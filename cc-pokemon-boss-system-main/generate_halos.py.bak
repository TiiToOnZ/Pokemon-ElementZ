# ─── MAIN ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    halos = {
        "halo_flame": (FLAME_PALETTE, FLAME_CONFIG),
        "halo_ice": (ICE_PALETTE, ICE_CONFIG),
        "halo_orbital": (ORBITAL_PALETTE, ORBITAL_CONFIG),
        "halo_pulse": (PULSE_PALETTE, PULSE_CONFIG),
        "halo_shadow": (SHADOW_PALETTE, SHADOW_CONFIG),
        "halo_vortex": (VORTEX_PALETTE, VORTEX_CONFIG),
    }
    for name, (palette, config) in halos.items():
        print(f"Generating {name}...")
        frames = []
        for f in range(TOTAL_FRAMES):
            frame = generate_rising_flame(f, TOTAL_FRAMES, palette, config)
            frames.append(frame)
            print(f"  frame {f + 1}/{TOTAL_FRAMES}", end="\r")
        print()
        sheet = make_sheet(frames)
        path = f"{OUTPUT_DIR}/{name}.png"
        sheet.save(path)
        print(f"  -> Saved {path}")

    print("Done!")
