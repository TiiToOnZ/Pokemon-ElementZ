    (255, 80, 20),    # bright red-orange core
    (230, 50, 10),    # intense red
    (200, 30, 5),     # deep red
    (170, 15, 0),     # dark red
    (140, 5, 0),      # darker red
    (100, 0, 0),      # deep crimson tip
]
FLAME_CONFIG = dict(
    seed=42, time_speed=3.0, core_alpha=255,
    base_half_width=1.0, tip_half_width=0.06, flame_reach=0.92, taper_exp=0.7,
    osc_amplitude=0.07, osc_wavelength=0.35, osc2_amplitude=0.04, osc2_wavelength=0.2,
    noise_distort=0.15, noise_freq_x=4.0, noise_freq_y=6.0, rise_speed=2.0,
    wisps=3, wisp_strength=0.3, wisp_width=0.15, glow_range=0.25,
)

